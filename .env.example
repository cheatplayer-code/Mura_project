# Core API
DEEPSEEK_API_KEY=sk-replace-with-real-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_FALLBACK_MODEL=deepseek-v4-pro
# Generate at least 32 random characters, for example: python -c "import secrets; print(secrets.token_urlsafe(32))"
WORKER_REGISTRATION_TOKEN=replace-with-at-least-32-random-characters

# Kaggle ASR worker
# Generate independently from WORKER_REGISTRATION_TOKEN.
KAGGLE_ASR_API_KEY=replace-with-at-least-32-random-characters
HF_TOKEN=hf_optional_for_public_model
ASR_DEVICE=cuda:0
MAX_UPLOAD_MB=25
MAX_AUDIO_SECONDS=900
CORE_BACKEND_URL=
