# Core API
DEEPSEEK_API_KEY=sk-replace-with-real-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_FALLBACK_MODEL=deepseek-v4-pro

# Generate independent values with at least 32 random characters:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
CORE_API_KEY=replace-with-at-least-32-random-characters
WORKER_REGISTRATION_TOKEN=replace-with-another-32-character-token
KAGGLE_ASR_API_KEY=replace-with-a-third-32-character-token

# PostgreSQL
DATABASE_URL=postgresql+psycopg://mura:mura@localhost:5432/mura
# true is convenient for the hackathon; production should use Alembic and set false.
DATABASE_AUTO_CREATE=true
AUDIO_STORAGE_DIR=.mura/audio
CORE_MAX_UPLOAD_MB=25
JOB_POLL_INTERVAL_SECONDS=1
ASR_RETRY_SECONDS=15
ASR_REQUEST_TIMEOUT_SECONDS=900

# Kaggle ASR worker
HF_TOKEN=hf_optional_for_public_model
ASR_DEVICE=cuda:0
MAX_UPLOAD_MB=25
MAX_AUDIO_SECONDS=900
CORE_BACKEND_URL=
